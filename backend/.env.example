# ============================================================================
# BACKEND ENVIRONMENT CONFIGURATION
# ============================================================================
# This is the backend-specific configuration file
# Copy to .env and fill in your actual values
# NEVER commit .env file - it's in .gitignore for security
#
# For all shared configuration, see the root .env.example
# ============================================================================

# MongoDB Configuration
# Local: mongodb://localhost:27017/prepmate-ai-studio
# Cloud: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://localhost:27017/prepmate-ai-studio

# Server Configuration
PORT=8000
NODE_ENV=development

# JWT Configuration
# Generate secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-jwt-secret-change-in-production
JWT_EXPIRY=7d

# External API Configuration (timeouts in milliseconds)
LEETCODE_API_TIMEOUT=10000
CODEFORCES_API_TIMEOUT=10000

# Logging
LOG_LEVEL=info

# AI Services Integration
# URL of the Python FastAPI AI service (port 8001)
AI_SERVICE_URL=http://localhost:8001

# Google Gemini API Key
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-gemini-api-key-here

# AI Service Configuration
AI_SERVICE_TIMEOUT_MS=30000
AI_SERVICE_MAX_RETRIES=3
AI_SERVICE_RETRY_DELAY_MS=1000

# Feature Flags for AI Services
ENABLE_AI_SERVICES=true
ENABLE_MENTOR=true
ENABLE_PRACTICE_REVIEW=true
ENABLE_INTERVIEW_SIMULATION=true
ENABLE_LEARNING_GENERATION=true
ENABLE_ML_MASTERY=true
ENABLE_ML_RETENTION=true
ENABLE_ML_WEAKNESS=true
ENABLE_ML_PLANNER=true
ENABLE_ML_READINESS=true