# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/prepmate-ai-studio

# Server Configuration
PORT=8000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=prepmate_ai_jwt_secret_key_change_in_production
JWT_EXPIRY=7d

# External API Configuration
LEETCODE_API_TIMEOUT=10000
CODEFORCES_API_TIMEOUT=10000

# Logging
LOG_LEVEL=info
# AI Services Integration
# URL of the Python FastAPI AI service (port 8001)
AI_SERVICE_URL=http://localhost:8001

# Google Gemini API Key - Get from: https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key-here

# AI Service Configuration
AI_SERVICE_TIMEOUT_MS=30000
AI_SERVICE_MAX_RETRIES=3
AI_SERVICE_RETRY_DELAY_MS=1000

# Feature Flags for AI Services
ENABLE_AI_SERVICES=true
ENABLE_MENTOR=true
ENABLE_PRACTICE_REVIEW=true
ENABLE_INTERVIEW_SIMULATION=true
ENABLE_LEARNING_GENERATION=true
ENABLE_ML_MASTERY=true
ENABLE_ML_RETENTION=true
ENABLE_ML_WEAKNESS=true
ENABLE_ML_PLANNER=true
ENABLE_ML_READINESS=true