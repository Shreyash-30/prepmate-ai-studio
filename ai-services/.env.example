# ============================================================================
# AI SERVICES LOCAL ENVIRONMENT OVERRIDES
# ============================================================================
# This file is OPTIONAL and FOR LOCAL DEVELOPMENT ONLY
# Copy this to .env and add any AI service-specific overrides
#
# The system will first load from the CENTRAL .env file at project root,
# then apply any overrides from this file.
#
# NEVER COMMIT .env FILES - SECURITY CRITICAL!
# See the central .env.example at ../.env.example for all available options
# ============================================================================

# ============================================================================
# MONGODB CONFIGURATION (Optional - Override root .env)
# ============================================================================
# MONGO_URI=mongodb://localhost:27017/prepmate-ai-studio

# ============================================================================
# LLM PROVIDER KEYS (Optional - Override root .env)
# ============================================================================
# Gemini (Google) - Get from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-key-here

# Groq (Fallback) - Get from: https://console.groq.com
# GROQ_API_KEY=your-key-here

# Together AI (Fallback) - Get from: https://www.together.ai/
# TOGETHER_API_KEY=your-key-here

# ============================================================================
# SERVICE CONFIGURATION (Optional)
# ============================================================================
# AI_SERVICE_PORT=8001
# AI_SERVICE_HOST=0.0.0.0

# ============================================================================
# LOGGING CONFIGURATION (Optional)
# ============================================================================
# LOG_LEVEL=INFO

