# ============================================================================
# CENTRAL ENVIRONMENT CONFIGURATION - PrepMate AI Studio
# ============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env file to Git - it will be ignored by .gitignore
# Get API keys from:
#   - Google Gemini: https://aistudio.google.com/apikey
#   - Groq: https://console.groq.com
#   - Together AI: https://www.together.ai/
# ============================================================================

# ============================================================================
# APPLICATION INFORMATION
# ============================================================================
VITE_APP_NAME=PrepMate AI Studio
VITE_APP_VERSION=1.0.0
NODE_ENV=development
VITE_DEBUG_MODE=false

# ============================================================================
# BACKEND (Node.js) CONFIGURATION
# ============================================================================
# Server port
PORT=8000

# JWT Configuration - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-jwt-secret-change-in-production
JWT_EXPIRY=7d

# External API Timeouts (milliseconds)
LEETCODE_API_TIMEOUT=10000
CODEFORCES_API_TIMEOUT=10000

# ============================================================================
# DATABASE CONFIGURATION (MongoDB)
# ============================================================================
# MongoDB connection URI
# Local: mongodb://localhost:27017/prepmate-ai-studio
# Cloud: mongodb+srv://username:password@cluster.mongodb.net/prepmate-ai-studio
MONGO_URI=mongodb://localhost:27017/prepmate-ai-studio
MONGODB_URI=mongodb://localhost:27017/prepmate-ai-studio

# ============================================================================
# AI SERVICE (Python FastAPI) CONFIGURATION
# ============================================================================
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
AI_SERVICE_URL=http://localhost:8001

# Timeout for AI service requests (milliseconds)
AI_SERVICE_TIMEOUT_MS=30000
AI_SERVICE_MAX_RETRIES=3
AI_SERVICE_RETRY_DELAY_MS=1000

# ============================================================================
# LLM PROVIDER CONFIGURATION (Google Gemini - Primary)
# ============================================================================
# Get key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# FALLBACK LLM PROVIDERS
# ============================================================================
# Groq (Fast, large context) - Get key from: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Together AI (Alternative provider) - Get key from: https://www.together.ai/
TOGETHER_API_KEY=your-together-api-key-here

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
VITE_API_BASE_URL=http://localhost:8000/api
VITE_AI_SERVICE_URL=http://localhost:8001

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# FEATURE FLAGS (AI SERVICES)
# ============================================================================
ENABLE_AI_SERVICES=true
ENABLE_MENTOR=true
ENABLE_PRACTICE_REVIEW=true
ENABLE_INTERVIEW_SIMULATION=true
ENABLE_LEARNING_GENERATION=true
ENABLE_ML_MASTERY=true
ENABLE_ML_RETENTION=true
ENABLE_ML_WEAKNESS=true
ENABLE_ML_PLANNER=true
ENABLE_ML_READINESS=true
